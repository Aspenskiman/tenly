# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tenly

# JWT Secrets — generate with: openssl rand -base64 64
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string

# Server
NODE_ENV=development
PORT=3000

# Email (console | smtp)
EMAIL_TRANSPORT=console

# SMTP (only needed if EMAIL_TRANSPORT=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=smtp_password
# EMAIL_FROM=noreply@tenly.app

# Client (set for production builds)
# VITE_API_URL=https://your-backend.onrender.com
